    <bean id = "userdataprovider" class="coupling.UserDatabaseProvider"  />
    <bean id = "newdataprovider" class="coupling.NewDatabaseProvider"  />
    <bean id = "webdataprovider" class="coupling.WebServiceDataProvider"  />

    <bean id = "usermanagerwithuserdataprovider" class="coupling.UserManager">
        <constructor-arg ref="userdataprovider"/>
    </bean>

    <bean id="usermanagerwithnewdataprovider" class="coupling.UserManager">
        <constructor-arg ref="newdataprovider"/>
    </bean>

    <bean id="usermanagerwithwebdataprovider" class="coupling.UserManager">
        <constructor-arg ref="webdataprovider"/>
    </bean>

</beans>